# Copy to .env (gitignored) and fill in. NEVER commit the real value.
#
# Azure SWA deployment token, used by `npm run deploy`. Get it with:
#   az staticwebapp secrets list -n <app-name> --query "properties.apiKey" -o tsv
# or from the Portal: your Static Web App -> Manage deployment token.
SWA_CLI_DEPLOYMENT_TOKEN=

# Note: the asset domain (e.g. https://assets.example.com) is NOT a secret — it's a public
# URL that ships in the UI bundle and lives committed in exiledata-ui's prod environment.ts.
# It doesn't belong here; this file is only for secrets.
