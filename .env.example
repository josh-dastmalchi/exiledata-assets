# Copy to .env (gitignored) and fill in. NEVER commit .env.
#
# Per-environment values for this repo's deploy. The token is a real secret; the domain is
# NOT (it's a public URL), but it's kept here so .env is the single local source of config.

# Azure SWA deployment token, used by `npm run deploy`. Get it with:
#   az staticwebapp secrets list -n <app-name> --query "properties.apiKey" -o tsv
# or from the Portal: your Static Web App -> Manage deployment token.
SWA_CLI_DEPLOYMENT_TOKEN=

# Public origin the assets are served from once Cloudflare -> SWA DNS is configured. Not a
# secret. Same value the UI uses as its prod assetsUrl (which lives committed in the UI repo;
# this copy is just a convenient local reference / deploy confirmation).
ASSETS_URL=https://assets.example.com
