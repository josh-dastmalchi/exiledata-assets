# Copy to .env (gitignored) and fill in. NEVER commit .env.
#
# Azure SWA deployment token, used by `npm run deploy`. The token alone identifies the target
# SWA — no URL is needed to deploy. Get it with:
#   az staticwebapp secrets list -n <app-name> --query "properties.apiKey" -o tsv
# or from the Portal: your Static Web App -> Manage deployment token.
SWA_CLI_DEPLOYMENT_TOKEN=
