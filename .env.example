# Copy to .env (gitignored) and fill in. NEVER commit .env.
#
# Cloudflare Pages credentials, used by `npm run deploy`. Wrangler reads both from the environment;
# they are never passed as CLI args or logged.
#   CLOUDFLARE_API_TOKEN  — dashboard -> My Profile -> API Tokens, scoped to Account > Cloudflare
#                           Pages > Edit.
#   CLOUDFLARE_ACCOUNT_ID — dashboard -> Workers & Pages (shown in the right sidebar).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional overrides (defaults shown). The production branch must match the Pages project's
# configured production branch for this to be a production (not preview) deploy.
# CF_PAGES_PROJECT=exiledata-assets
# CF_PAGES_BRANCH=main
